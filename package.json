{
  "name": "netex",
  "version": "2.1.7-rc4",
  "scripts": {
    "ng": "ng",
    "start:dev": "ng serve --configuration=dev",
    "start:dev_server": "ng serve --configuration=dev_server",
    "start:prod": "ng serve --configuration=production",
    "build": "ng build",
    "test": "ng test",
    "lint": "htmlhint",
    "e2e": "ng e2e",
    "build-prod": "ng build --configuration=production --output-hashing=none",
    "build-stable": "ng build --configuration=stable --output-hashing=none",
    "build-dev": "ng build --configuration=development --output-hashing=none",
    "build-dev-server": "ng build --configuration=development_server --output-hashing=none",
    "package-es5": "cd dist/netex && cat runtime-es5.js polyfills-es5.js main-es5.js > bundle-es5.js",
    "package-es2015": "cd dist/netex && cat runtime-es2015.js polyfills-es2015.js main-es2015.js > bundle-es2015.js",
    "bundle": "npm run build-prod netex && npm run package-es5 && npm run package-es2015",
    "build:clean": "python3 prefixCSS.py --stage cleanup",
    "build:prepare": "python3 prefixCSS.py --stage prepare",
    "build:drugstone": "npm run build:prepare && cd build-tmp && npm run build-prod netex && node build-netex.js && cd .. && rm -rf drugsTone-build && cp -r build-tmp/drugsTone-build . && npm run build:clean",
    "build:drugstone-stable": "npm run build:prepare && cd build-tmp && npm run build-stable netex && node build-netex.js && cd .. && rm -rf drugsTone-build && cp -r build-tmp/drugsTone-build . && npm run build:clean",
    "build:drugstone-dev": "npm run build:prepare && cd build-tmp && npm run build-dev netex && node build-netex.js && cd .. && rm -rf drugsTone-build && cp -r build-tmp/drugsTone-build . && npm run build:clean",
    "build:drugstone-dev-server": "npm run build:prepare && cd build-tmp && npm run build-dev-server netex && node build-netex.js && cd .. && rm -rf drugsTone-build && cp -r build-tmp/drugsTone-build . && npm run build:clean"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^18.2.14",
    "@angular/cdk": "^17.3.10",
    "@angular/common": "^18.2.14",
    "@angular/compiler": "^18.2.14",
    "@angular/core": "^18.2.14",
    "@angular/elements": "^18.2.14",
    "@angular/forms": "^18.2.14",
    "@angular/localize": "^18.2.14",
    "@angular/material": "^16.2.0",
    "@angular/platform-browser": "^18.2.14",
    "@angular/platform-browser-dynamic": "^18.2.14",
    "@angular/router": "^18.2.14",
    "@ng-bootstrap/ng-bootstrap": "^15.1.2",
    "@ng-select/ng-select": "^12.0.7",
    "animate.css": "^4.1.1",
    "bulma": "^0.9.2",
    "bulma-toast": "^2.4.1",
    "bulma-tooltip": "^3.0.2",
    "canvas2svg-visjs": "^1.0.21",
    "convert-svg-to-png": "^0.7.1",
    "document-register-element": "^1.7.2",
    "dom-to-image-cross-origin": "^2.6.7",
    "json5": "^2.2.0",
    "lodash.merge": "^4.6.2",
    "ng-multiselect-dropdown": "^1.0.0",
    "primeng": "^17.18.15",
    "rxjs": "^7.8.2",
    "tslib": "^2.0.0",
    "zone.js": "^0.14.10"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "^17.0.2",
    "@angular-devkit/build-angular": "^18.2.21",
    "@angular/cli": "^18.2.21",
    "@angular/compiler-cli": "^18.2.14",
    "@angular/language-service": "^18.2.14",
    "@popperjs/core": "^2.11.8",
    "@types/jasmine": "~3.7.7",
    "@types/jasminewd2": "^2.0.9",
    "@types/node": "^15.12.2",
    "concat": "^1.0.3",
    "fs-extra": "^10.0.0",
    "htmlhint": "^1.1.4",
    "jasmine-core": "~3.8.0",
    "jasmine-spec-reporter": "~7.0.0",
    "js-yaml": "^3.14.2",
    "karma": "~6.3.3",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage-istanbul-reporter": "~3.0.2",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "^1.5.0",
    "lodash": "^4.17.23",
    "raw-loader": "^4.0.2",
    "ts-node": "~10.0.0",
    "typescript": "~5.4.5",
    "undici": "^7.18.2",
    "webpack": "^5.105.4"
  },
  "overrides": {
    "glob-parent": "6.0.2",
    "node-forge": ">=1.3.2",
    "tar": ">=7.5.8",
    "minimatch": "~3.1.3",
    "semver": ">=7.5.2",
    "xml2js": ">=0.5.0",
    "tough-cookie": ">=4.1.3",
    "codelyzer": {
      "@angular/core": ">=10.2.5"
    },
    "ws": ">=8.17.1",
    "qs": ">=6.14.2",
    "tar-fs": ">=3.1.1",
    "webpack-dev-middleware": ">5.3.3",
    "webpack-dev-server": ">5.2.0",
    "esbuild": "0.25.0",
    "@babel/runtime": ">7.26.10",
    "tmp": ">=0.2.4"
  }
}